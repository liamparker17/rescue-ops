{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL", "ENCRYPTION_KEY", "NEXT_PUBLIC_SENTRY_DSN", "NEXT_PUBLIC_TRIAGE_URL", "NEXT_PUBLIC_OPS_URL", "NEXT_PUBLIC_PIPELINE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "ENCRYPTION_KEY", "NEXT_PUBLIC_SENTRY_DSN", "NEXT_PUBLIC_TRIAGE_URL", "NEXT_PUBLIC_OPS_URL", "NEXT_PUBLIC_PIPELINE_URL"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "node_modules/.prisma/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "db:generate": { "cache": false },
    "db:push": { "cache": false },
    "db:migrate": { "cache": false },
    "db:seed": { "cache": false }
  }
}
